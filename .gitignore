# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# ── Webapp (Rails) ──
webapp/.bundle
webapp/log/*
webapp/tmp/*
!webapp/log/.keep
!webapp/tmp/.keep
webapp/.byebug_history
webapp/.idea
webapp/public/uploads
webapp/public/assets
webapp/node_modules
webapp/config/application.yml

# ── Desktop (Electron) ──
desktop/node_modules
desktop/dist
desktop/build-userdata

# ── Build inputs (never commit; large / contain user content) ──
# Rails pg_dump output, unpacked or binary
*-backup-unpacked.sql
*-backup.dump
# CarrierWave uploads snapshots that feed `prepare-seed`
spherelink-backup-*/

# ── Editor / OS ──
.idea
.DS_Store
